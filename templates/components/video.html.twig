{% import "_message.html.twig" as message %}

<div class="card mx-auto shadow-lg" {{ attributes.defaults(stimulus_controller('video')) }}>
    <div class="card-header p-2">
        {{ ux_icon('video') }}
        <strong class="ms-1 pt-1 d-inline-block">Video Bot</strong>
    </div>
    <div id="chat-body" class="card-body p-2 overflow-auto">
        <div id="welcome" class="text-center mt-5 p-4 bg-white rounded-5 shadow-sm w-75 mx-auto">
            <div class="mb-2">
                <video id="videoFeed" autoplay playsinline></video>
            </div>
            <canvas id="canvas" class="d-none"></canvas>
            <i data-loading="action(submit)|hide" class="text-muted">{{ this.caption|markdown_to_html }}</i>
            <div data-loading="action(submit)|show" class="text-muted">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <i>Analyzing the frame…</i>
            </div>
        </div>
    </div>
    <div class="card-footer p-2">
        <form class="input-group" data-action="submit->video#submit">
            <input autofocus id="chat-message"
                   data-model="norender|instruction"
                   data-loading="action(submit)|addAttribute(disabled)"
                   type="text" class="form-control border-0" placeholder="What do you see?">
            <button class="btn btn-outline-secondary border-0" data-loading="action(submit)|addAttribute(disabled)">
                <span data-loading="action(submit)|hide">
                    {{ ux_icon('send') }} Submit
                </span>
                <span data-loading="action(submit)|show">
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    Thinking…
                </span>
            </button>
        </form>
    </div>
</div>
